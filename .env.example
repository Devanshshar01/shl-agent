# Copy this to .env and fill in for local dev.
# Do NOT commit the real .env.

ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used per turn. Defaults to claude-sonnet-4-6.
# Any Anthropic model works; for a free-tier alternative see the README's
# "Swapping the LLM provider" section.
SHL_AGENT_MODEL=claude-sonnet-4-6
